# ============================================
# Arcane Environment Variables
# ============================================
# Copy this file: cp .env.example .env
# Then fill in the values below.

# ---------- Security Credentials ----------
# Generate a 32-byte hex key (e.g. openssl rand -hex 32)
ENCRYPTION_KEY=your_32_byte_hex_encryption_key_here

# Generate a JWT Secret (e.g. openssl rand -hex 32)
JWT_SECRET=your_jwt_secret_here

# ---------- System Settings ----------
PUID=1000
PGID=1000
TZ=Europe/Paris

# ---------- Networking ----------
# Port on host to expose Arcane Dashboard
ARCANE_PORT=3552
DOMAIN=apps.local

# ---------- Storage ----------
# Host path where Arcane projects (stacks) will be saved
PROJECTS_DIR=./projects

# Host path for local templates (.yml / .yaml)
TEMPLATES_DIR=./templates
